        best_indicators_df = generate_best_indicator_table(correlations, max_lag)
        best_indicators_csv = os.path.join(csv_dir, f"{timestamp}_{symbol}_{timeframe}_best_indicators.csv")
        best_indicators_df.to_csv(best_indicators_csv,index=False)
        print(f"Generated best indicator table: {best_indicators_csv}")
        logging.info(f"Best table saved: {best_indicators_csv}")
    except Exception as e:
        logging.error(f"Best table error: {e}")
        print(f"Best table error: {e}")

    if save_correlation_csv:
        try:
            generate_correlation_csv(correlations, max_lag, f"{symbol}_{timeframe}", csv_dir)
        except Exception as e:
            logging.error(f"Correlation CSV error: {e}")
            print(f"Correlation CSV error: {e}")

    data['Date'] = pd.to_datetime(data['Date']).dt.tz_localize(None)
    latest_date_in_data = data['Date'].max()
    print(f"\nLatest date/time in data: {latest_date_in_data}")
    logging.info(f"Latest in data: {latest_date_in_data}")

    current_datetime = datetime.now()
    time_interval_seconds_map = {'second':1,'minute':60,'hour':3600,'day':86400,'week':604800}
    if time_interval not in time_interval_seconds_map:
        logging.error(f"Unsupported interval {time_interval}")
        print(f"Unsupported interval {time_interval}")
        sys.exit(1)

    time_diff_seconds = (current_datetime - latest_date_in_data).total_seconds()
    lag_periods_behind_current = int(time_diff_seconds / time_interval_seconds_map[time_interval])
    print(f"Data is {lag_periods_behind_current} {time_interval}(s) behind current time.")
    logging.info(f"Data behind current: {lag_periods_behind_current}")

    print("\nEnter future date/time for prediction. Format: YYYYMMDD-HHMM or relative like +1h, or blank for current.")
    user_input = input("Future date/time: ").strip()
    try:
        future_datetime = parse_date_time_input(user_input, current_datetime) if user_input else current_datetime
        print(f"Using future date/time: {future_datetime}" if user_input else f"No input, using current: {future_datetime}")
    except ValueError as e:
        print(f"Date parse error: {e}")
        logging.error(f"Date parse error: {e}")
        sys.exit(1)

    lag_seconds = (future_datetime - latest_date_in_data).total_seconds()
    if lag_seconds<=0:
        print("Future must be after latest data.")
        logging.error("Future < latest data.")
        sys.exit(1)

    lag_periods = int(lag_seconds/time_interval_seconds_map[time_interval])
    if lag_periods<1:
        print("Must be at least one lag ahead.")
        logging.error("Lag <1.")
        sys.exit(1)
    if lag_periods>max_lag:
        print(f"Lag must be ≤ {max_lag}.")
        logging.error(f"Lag {lag_periods}>{max_lag}.")
        sys.exit(1)

    print(f"Lag period: {lag_periods} {time_interval}(s)")
    logging.info(f"Lag period: {lag_periods} {time_interval}(s)")

    try:
        perform_linear_regression(data, correlations, max_lag, time_interval, timestamp, f"{symbol}_{timeframe}", future_datetime, lag_periods)
        logging.info("Linear regression done.")
    except TypeError as te:
        logging.error(f"LR TypeError: {te}")
        print(f"LR error: {te}")
    except Exception as e:
        logging.error(f"LR fail: {e}")
        print(f"LR fail: {e}")

    try:
        advanced_price_prediction(data, correlations, max_lag, time_interval, timestamp, f"{symbol}_{timeframe}", future_datetime, lag_periods)
        logging.info("Advanced prediction done.")
    except TypeError as te:
        logging.error(f"Adv TypeError: {te}")
        print(f"Adv error: {te}")
    except Exception as e:
        logging.error(f"Adv fail: {e}")
        print(f"Adv fail: {e}")

    logging.info("All done.")
    print("All processes completed successfully.")

if __name__=="__main__":
    main()


